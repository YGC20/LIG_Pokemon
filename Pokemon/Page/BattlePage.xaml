<Page x:Class="Pokemon.Page.BattlePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Pokemon.Page"
      mc:Ignorable="d"
      d:DesignHeight="850" d:DesignWidth="600"
      Title="BattlePage">

    <Page.Resources>
        <Style x:Key="BossMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5A3D8C"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                            Background="#E6FFFFFF"
                            BorderBrush="GreenYellow"
                            BorderThickness="3"
                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#CCFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="2*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Frame Grid.Row="0"
               x:Name="BattleImageFrame"
               NavigationUIVisibility="Hidden"/>

        <!-- 상대 포켓몬 정보 (우상단) -->
        <StackPanel Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="10">
            <TextBlock x:Name="OppNameText" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Right"/>
            <ProgressBar x:Name="OppHpBar" Width="150" Height="14" Minimum="0" Foreground="LimeGreen"/>
        </StackPanel>
        <Image x:Name="OppSpriteImage" Grid.Row="0" Width="110" Stretch="Uniform"
               HorizontalAlignment="Right" VerticalAlignment="Center" Margin="20,40,20,0"/>

        <!-- 내 포켓몬 정보 (좌하단) -->
        <Image x:Name="PlayerSpriteImage" Grid.Row="0" Width="140" Stretch="Uniform"
               HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="10,0,0,10"/>
        <StackPanel Grid.Row="0" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="150,0,0,20">
            <TextBlock x:Name="PlayerNameText" FontSize="16" FontWeight="Bold" Foreground="White"/>
            <ProgressBar x:Name="PlayerHpBar" Width="150" Height="14" Minimum="0" Foreground="LimeGreen"/>
        </StackPanel>

        <Border Grid.Row="1"
                Background="#E6FFFFFF"
                BorderBrush="DarkGray"
                BorderThickness="10"
                CornerRadius="16"
                Margin="1"
                Padding="15,10">
            <TextBlock x:Name="TextBox"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="#5A3D8C"
                       TextWrapping="Wrap"
                       HorizontalAlignment="Left"
                       VerticalAlignment="Top"/>
        </Border>

        <Frame Grid.Row="2"
               x:Name="MenuButtonFrame"
               Source="/Page/MenuButtonPage.xaml"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
