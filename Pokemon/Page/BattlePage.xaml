<Page x:Class="Pokemon.Page.BattlePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:b="http://schemas.microsoft.com/xaml/behaviors"
      xmlns:local="clr-namespace:Pokemon.Page"
      mc:Ignorable="d"
      d:DesignHeight="700" d:DesignWidth="700"
      Title="BattlePage">
 
    <b:Interaction.Triggers>
        <b:EventTrigger EventName="PreviewMouseDown">
            <b:CallMethodAction TargetObject="{Binding}" MethodName="OnAnyInputDetected" />
        </b:EventTrigger>
        <b:EventTrigger EventName="PreviewKeyDown">
            <b:CallMethodAction TargetObject="{Binding}" MethodName="OnAnyInputDetected" />
        </b:EventTrigger>
    </b:Interaction.Triggers>

    <Page.Resources>
        <Style x:Key="BossMenuButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="220"/>
            <Setter Property="Height" Value="70"/>
            <Setter Property="Margin" Value="15"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Foreground" Value="#5A3D8C"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="ButtonBorder"
                            Background="#E6FFFFFF"
                            BorderBrush="GreenYellow"
                            BorderThickness="3"
                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center"
                                           VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="ButtonBorder" Property="Background" Value="#CCFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="380"/>
            <RowDefinition Height="0.6*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>

        <Frame Grid.Row="0"
               x:Name="BattleImageFrame"
               NavigationUIVisibility="Hidden"/>

        <!-- 상대 포켓몬 정보 (우상단): 이름/체력 박스 + 스프라이트를 한 덩어리로 배치 -->
        <StackPanel Grid.Row="0"
                    x:Name="OppPokemonPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="10,70,95,0">
            <Border Background="#E6FFFFFF" BorderBrush="DarkGray" BorderThickness="2" CornerRadius="10"
                    Padding="10,6" VerticalAlignment="Center" Margin="0,0,100,30">
                <StackPanel>
                    <TextBlock x:Name="OppNameText" FontSize="20" FontWeight="Bold" Foreground="#5A3D8C" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="OppHpBar" Width="200" Height="14" Minimum="0" Maximum="100" Foreground="LimeGreen"/>
                </StackPanel>
            </Border>
            <Grid Width="170" VerticalAlignment="Center">
                <Ellipse Width="100" Height="24" Fill="#802B2B2B"
                          HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10">
                    <Ellipse.Effect>
                        <BlurEffect Radius="8"/>
                    </Ellipse.Effect>
                </Ellipse>
                <Image x:Name="OppSpriteImage" Stretch="Uniform"/>
            </Grid>
        </StackPanel>

        <!-- 내 포켓몬 정보 (좌하단): 스프라이트 + 이름/체력 박스를 한 덩어리로 배치 -->
        <StackPanel Grid.Row="0"
                    x:Name="PlayerPokemonPanel"
                    Orientation="Horizontal"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Bottom"
                    Margin="50,0,0,-20">
        <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="50,0,0,-30">
            <Image x:Name="PlayerSpriteImage" Width="170" Stretch="Uniform" VerticalAlignment="Center"/>
            <Border Background="#E6FFFFFF" BorderBrush="DarkGray" BorderThickness="2" CornerRadius="10"
                    Padding="10,6" VerticalAlignment="Center" Margin="120,0,0,-30">
                <StackPanel>
                    <TextBlock x:Name="PlayerNameText" FontSize="20" FontWeight="Bold" Foreground="#5A3D8C" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="PlayerHpBar" Width="200" Height="14" Minimum="0" Maximum="100" Foreground="LimeGreen"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- 공격 이펙트 오버레이: 포켓몬 스프라이트 위에 그려지는 투사체/타격 효과 -->
        <Canvas Grid.Row="0"
                x:Name="EffectCanvas"
                Background="Transparent"
                IsHitTestVisible="False"
                ClipToBounds="True"/>

        <!-- 상대 포켓몬 자리에서 등장했다가 퇴장하는 트레이너 -->
        <Grid Grid.Row="0"
              x:Name="TrainerIntroStage"
              Panel.ZIndex="20"
              IsHitTestVisible="False">
            <Image x:Name="TrainerIntroImage"
                   Width="190"
                   Height="250"
                   Margin="0,25,75,0"
                   HorizontalAlignment="Right"
                   VerticalAlignment="Top"
                   Stretch="Uniform"
                   Opacity="0"
                   RenderOptions.BitmapScalingMode="NearestNeighbor">
                <Image.RenderTransform>
                    <TranslateTransform x:Name="TrainerIntroTransform"
                                        X="180"/>
                </Image.RenderTransform>
            </Image>
        </Grid>

        <Border Grid.Row="1"
                x:Name="MessageBorder"
                Background="#E6FFFFFF"
                BorderBrush="IndianRed"
                BorderThickness="10"
                CornerRadius="16"
                Margin="1"
                Padding="15,10">
            <StackPanel> 
                <TextBlock x:Name="TextBox"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#5A3D8C"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,7,0,7"/>
                 <TextBlock x:Name="TextBox2"
                    FontSize="18"
                    FontWeight="Bold"
                    Foreground="#5A3D8C"
                    TextWrapping="Wrap"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top"
                    Margin="0,7,0,7"/>
            </StackPanel>
        </Border>

        <Frame Grid.Row="2"
               x:Name="MenuButtonFrame"
               Source="/Page/MenuButtonPage.xaml"
               IsEnabled="False"
               NavigationUIVisibility="Hidden"/>
    </Grid>
</Page>
