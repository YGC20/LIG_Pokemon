<Page x:Class="Pokemon.Page.ResultPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
      xmlns:local="clr-namespace:Pokemon.Page"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="ResultPage">

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#B347D9" Offset="0.0"/>
                <GradientStop Color="#6A5ACD" Offset="0.5"/>
                <GradientStop Color="#45E0E0" Offset="1.0"/>
            </LinearGradientBrush>
        </Grid.Background>

        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="ResultText"
                       FontSize="36"
                       FontWeight="Bold"
                       Foreground="White"
                       TextAlignment="Center"
                       TextWrapping="Wrap"
                       Margin="20"/>
            <Button x:Name="ConfirmButton" Content="확인" Width="160" Height="50" FontSize="18" FontWeight="Bold"
                    Click="ConfirmButtonClick"/>
        </StackPanel>
    </Grid>
</Page>
